<script>
/* ═══════════════════════════════════════════════════════════
   RENDER ENGINE — Reads CONFIG and builds the DOM
═══════════════════════════════════════════════════════════ */

function el(tag, cls, html, attrs={}) {
  const e = document.createElement(tag);
  if(cls) e.className = cls;
  if(html !== undefined) e.innerHTML = html;
  Object.entries(attrs).forEach(([k,v]) => e.setAttribute(k,v));
  return e;
}

// ── Page meta ─────────────────────────────────────────────
document.getElementById('page-title').textContent = `${CONFIG.name} — B2B Sales & Key Account Manager`;
document.getElementById('hero-name').innerHTML = `<span class="grad-text">${CONFIG.name.split(' ')[0]}</span> ${CONFIG.name.split(' ').slice(1).join(' ')}`;
document.getElementById('hero-tagline').textContent = CONFIG.tagline;
document.getElementById('hero-loc').innerHTML = `📍 ${CONFIG.location}`;
document.getElementById('hero-resume').href = CONFIG.resumeLink;
document.getElementById('about-name').textContent = CONFIG.name;
document.getElementById('about-avatar').textContent = CONFIG.name.split(' ').map(w=>w[0]).join('').slice(0,2);
document.getElementById('footer-copy').textContent = `© ${new Date().getFullYear()} ${CONFIG.name} · Built with ❤ and GitHub`;

// ── Stats bar ─────────────────────────────────────────────
const sb = document.getElementById('stats-bar');
CONFIG.stats.forEach((s, i) => {
  if(i > 0) sb.appendChild(el('div','stat-divider'));
  const item = el('div','stat-item');
  item.innerHTML = `<div class="stat-number" data-target="${s.value}" data-suffix="${s.suffix}">0${s.suffix}</div>
                    <div class="stat-label">${s.label}</div>`;
  sb.appendChild(item);
});

// ── About tags ────────────────────────────────────────────
const atags = document.getElementById('about-tags');
['B2B Sales','KAM','Professional Lighting','Karnataka','MBA'].forEach(t => {
  atags.appendChild(el('span','tag',t));
});

// ── About body ────────────────────────────────────────────
const ab = document.getElementById('about-body');
CONFIG.about.split('\n\n').filter(Boolean).forEach(para => {
  ab.appendChild(el('p','',para));
});

// ── Education ─────────────────────────────────────────────
CONFIG.education.forEach((edu, i) => {
  const d = document.getElementById(`edu-${i}`);
  if(!d) return;
  d.innerHTML = `<div class="edu-degree">${edu.degree}</div>
                 <div class="edu-inst">${edu.institution}</div>
                 <div class="edu-year">${edu.year}</div>
                 <div class="edu-note">${edu.highlight}</div>`;
});

// ── Career timeline ───────────────────────────────────────
const tl = document.getElementById('career-timeline');
CONFIG.career.forEach((job, i) => {
  const badgeMap = {promotion:'badge-promo',job:'badge-job',internship:'badge-intern'};
  const dotClass = job.type==='promotion'?'promo':job.type==='internship'?'intern':'';
  const badgeLabel = job.type==='promotion'?'🏅 Promoted':job.type==='internship'?'Internship':'Full-time';
  const item = el('div','timeline-item reveal');
  item.style.animationDelay = `${i*0.12}s`;
  item.innerHTML = `
    <div class="timeline-dot ${dotClass}" title="${job.role}"></div>
    <div class="timeline-card">
      <div class="tl-head">
        <div class="tl-role">${job.role}</div>
        <span class="tl-badge ${badgeMap[job.type]}">${badgeLabel}</span>
      </div>
      <div class="tl-company">${job.company}</div>
      <div class="tl-div">${job.division}</div>
      <div class="tl-period">🗓 ${job.period}</div>
      <ul class="tl-bullets">${job.bullets.map(b=>`<li>${b}</li>`).join('')}</ul>
      <div class="skill-chips">${job.skills.map(s=>`<span class="chip">${s}</span>`).join('')}</div>
    </div>`;
  tl.appendChild(item);
});

// ── Skills ────────────────────────────────────────────────
const sg = document.getElementById('skills-grid');
CONFIG.skills.forEach(sk => {
  const row = el('div','skill-row reveal');
  row.innerHTML = `
    <div class="skill-top">
      <span class="skill-name">${sk.name}</span>
      <span class="skill-pct">${sk.pct}%</span>
    </div>
    <div class="skill-track"><div class="skill-fill" data-pct="${sk.pct}"></div></div>`;
