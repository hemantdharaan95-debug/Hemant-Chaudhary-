});

// ── Projects ──────────────────────────────────────────────
const pg = document.getElementById('projects-grid');
CONFIG.projects.forEach(p => {
  const card = el('div','proj-card reveal');
  card.innerHTML = `
    <div class="proj-icon-bar">
      <div class="proj-icon">${p.icon}</div>
      <div class="proj-icon-info">
        <div class="proj-title">${p.title}</div>
        <div class="proj-sub">${p.subtitle}</div>
      </div>
    </div>
    <div class="proj-body">
      <div class="proj-section">
        <div class="proj-label">Problem</div>
        <p>${p.problem}</p>
      </div>
      <div class="proj-section">
        <div class="proj-label">Solution</div>
        <p>${p.solution}</p>
      </div>
      <div class="proj-section">
        <div class="proj-label">Outcome</div>
        <p>${p.outcome}</p>
      </div>
    </div>
    <div class="proj-tags">${p.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div>`;
  pg.appendChild(card);
});

// ── Certifications ────────────────────────────────────────
const cg = document.getElementById('certs-grid');
const certIcons = ['🎓','🏅','📜','⭐','🔖'];
CONFIG.certifications.forEach((c,i) => {
  const card = el('div','cert-card reveal');
  card.innerHTML = `
    <div class="cert-icon">${certIcons[i % certIcons.length]}</div>
    <div>
      <div class="cert-name">${c.name}</div>
      <div class="cert-meta">${c.issuer} · ${c.year}</div>
    </div>
    ${c.link && c.link !== '#' ? `<a href="${c.link}" target="_blank" class="cert-link">Verify ↗</a>` : ''}`;
  cg.appendChild(card);
});

// ── Sessions ──────────────────────────────────────────────
const sesG = document.getElementById('sessions-grid');
CONFIG.sessions.forEach(s => {
  const card = el('div','session-card reveal');
  card.innerHTML = `
    <div class="session-icon">${s.icon}</div>
    <div class="session-title">${s.title}</div>
    <div class="session-dur">⏱ ${s.duration}</div>
    <ul class="session-bullets">${s.bullets.map(b=>`<li>${b}</li>`).join('')}</ul>
    <div class="session-footer">
      <div class="session-price">${s.price}</div>
      <a href="#contact" class="btn btn-outline" style="font-size:.8rem;padding:.4rem .9rem">Book →</a>
    </div>`;
